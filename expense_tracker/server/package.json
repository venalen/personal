{
  "name": "expense-tracker-server",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "/opt/homebrew/opt/postgresql@16/bin/psql ${DATABASE_URL:-postgresql://localhost/expense_tracker} -f src/seed.sql",
    "pretest": "/opt/homebrew/opt/postgresql@16/bin/createdb expense_tracker_test 2>/dev/null || true",
    "test": "DATABASE_URL=postgresql://localhost/expense_tracker_test vitest run"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
